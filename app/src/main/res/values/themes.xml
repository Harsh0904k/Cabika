<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base application theme using Material3 (Light Only) -->
    <style name="Base.Theme.Vcab" parent="Theme.Material3.Light.NoActionBar">
        <!-- Customize your light theme here -->
        <item name="materialButtonStyle">@style/Widget.MaterialComponents.Button</item>

        <!-- Ensure content doesn't go under status bar -->
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowFullscreen">false</item>
    </style>

    <!-- Extend your base theme -->
    <style name="Theme.Vcab" parent="Base.Theme.Vcab" />

    <!-- Optional legacy Material Components theme -->
    <style name="AppTheme" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Customize your theme here -->
        <item name="materialButtonStyle">@style/Widget.MaterialComponents.Button</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowFullscreen">false</item>
    </style>

</resources>
