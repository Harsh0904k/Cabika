<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Shadow/Elevation effect -->
    <item android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="#1A000000"/> <!-- Light translucent black -->
            <size android:height="72dp"/>
        </shape>
    </item>

    <!-- Main background layer -->
    <item android:top="0dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFBFB"/> <!-- Light, modern background -->
            <stroke android:width="2dp" android:color="#C1FFEDEB"/> <!-- Thin border -->
            <corners android:topLeftRadius="0dp" android:topRightRadius="0dp"/> <!-- Smooth top curve -->
        </shape>
    </item>

</layer-list>
