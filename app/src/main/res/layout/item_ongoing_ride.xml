<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:layout_width="250dp"
    android:layout_height="wrap_content"
    android:background="@drawable/card_gradient_bg"
    card_view:cardCornerRadius="20dp"
    card_view:cardElevation="12dp"
    android:layout_marginEnd="4dp"
    android:clipChildren="false"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp"
        android:orientation="vertical"
        android:gravity="start">

        <!-- Pickup & Drop -->
        <TextView
            android:id="@+id/txtPickup"
            android:text="From: Campus"
            android:textStyle="bold"
            android:textSize="17sp"
            android:layout_marginBottom="2dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/txtDrop"
            android:text="To: Airport"
            android:textSize="16sp"
            android:layout_marginBottom="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- Time -->
        <TextView
            android:id="@+id/txtTime"
            android:text="📅 Today • 5 PM"
            android:textSize="14sp"
            android:textColor="#666666"
            android:layout_marginBottom="6dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- Status -->
        <TextView
            android:id="@+id/txtStatus"
            android:text="Waiting"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- Passengers -->
        <TextView
            android:id="@+id/txtPassengers"
            android:text="👤 1/3 passengers"
            android:textSize="14sp"
            android:textColor="#666666"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>
