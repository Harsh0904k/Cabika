<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#FFFFFF"
    android:padding="16dp"
    android:orientation="vertical"
    android:gravity="center_horizontal">

    <!-- 1️⃣ Top Section - Logo & Tagline -->
    <ImageView
        android:id="@+id/logoImage"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/ic_vcab_logo"
        android:contentDescription="vCab Logo" />

    <TextView
        android:id="@+id/taglineText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Share your ride. Save your fare."
        android:textColor="#333333"
        android:textSize="18sp"
        android:fontFamily="sans-serif-medium"
        android:layout_marginTop="8dp"
        android:textAlignment="center" />

    <!-- 2️⃣ Hero Illustration / Image -->
    <ImageView
        android:id="@+id/heroIllustration"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_marginTop="24dp"
        android:scaleType="fitCenter"
        android:src="@drawable/hero_illustration"
        android:contentDescription="Students sharing a cab illustration" />

    <!-- 3️⃣ Key Benefits Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="24dp"
        android:gravity="center"
        android:weightSum="3">

        <!-- Card 1 -->
        <LinearLayout
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/smartphone" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Book Easily"
                android:textStyle="bold"
                android:textColor="#000000"
                android:layout_marginTop="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select your pickup and drop in seconds"
                android:textSize="12sp"
                android:textColor="#666666"
                android:textAlignment="center" />
        </LinearLayout>

        <!-- Card 2 -->
        <LinearLayout
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_handshake" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Share and Save"
                android:textStyle="bold"
                android:textColor="#000000"
                android:layout_marginTop="8dp"
                android:textAlignment="center"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Split the cost with others"
                android:textSize="12sp"
                android:textColor="#666666"
                android:textAlignment="center" />
        </LinearLayout>

        <!-- Card 3 -->
        <LinearLayout
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_secure" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Secure"
                android:textStyle="bold"
                android:textColor="#000000"
                android:layout_marginTop="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Only verified students"
                android:textSize="12sp"
                android:textColor="#666666"
                android:textAlignment="center" />
        </LinearLayout>
    </LinearLayout>

    <!-- 4️⃣ Call to Action Buttons -->
    <Button
        android:id="@+id/btnSignUp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Sign Up"
        android:textColor="#FF6F00"
        android:backgroundTint="#FFF3E0"
        android:textAllCaps="false"
        android:layout_marginTop="32dp"
        android:padding="12dp"
        app:cornerRadius="16dp"
        app:strokeColor="#FF6F00"
        app:strokeWidth="2dp"
        android:fontFamily="sans-serif-medium" />

    <Button
        android:id="@+id/btnLogin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Log In"
        android:textColor="#FFF3E0"
        android:backgroundTint="#FF6F00"
        android:textAllCaps="false"
        android:layout_marginTop="12dp"
        android:padding="12dp"
        app:cornerRadius="16dp"
        app:strokeColor="#FFF3E0"
        app:strokeWidth="2dp"
        android:fontFamily="sans-serif-medium" />

    <!-- 5️⃣ Footer Links -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="40dp"
        android:paddingBottom="20dp">

        <TextView
            android:id="@+id/tvTerms"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Terms and Conditions"
            android:textColor="#999999"
            android:textSize="12sp"
            android:layout_marginEnd="20dp" />

        <TextView
            android:id="@+id/tvPrivacy"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Privacy Policy"
            android:textColor="#999999"
            android:textSize="12sp"
            android:layout_marginEnd="20dp" />

        <TextView
            android:id="@+id/tvContact"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Contact / Help"
            android:textColor="#999999"
            android:textSize="12sp" />
    </LinearLayout>

</LinearLayout>
