<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/homeLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground"
    tools:context=".HomeActivity">

    <!-- Scrollable content -->
    <ScrollView
        android:id="@+id/homeScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/contactText"
        android:padding="32dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <!-- Welcome -->
            <TextView
                android:id="@+id/welcomeText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Welcome to Cabika"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="?android:attr/textColorPrimary"
                android:layout_marginBottom="12dp" />

            <!-- Description -->
            <TextView
                android:id="@+id/appDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Book shared cabs easily.\nMatch with students or drivers.\nSave time and share the fare."
                android:textSize="17sp"
                android:textColor="?android:attr/textColorSecondary"
                android:gravity="center"
                android:lineSpacingExtra="8dp"
                android:layout_marginBottom="16dp" />

            <!-- Beta Notice Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?android:attr/colorBackgroundFloating"
                android:padding="16dp"
                android:elevation="4dp"
                android:orientation="vertical"
                android:layout_marginBottom="24dp">

                <TextView
                    android:id="@+id/betaNote"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="App is still under development — this is the first beta rollout. Please share your feedback for improvements."
                    android:textColor="@android:color/holo_red_dark"
                    android:textSize="15sp"
                    android:lineSpacingExtra="6dp"
                    android:gravity="center" />

                <com.airbnb.lottie.LottieAnimationView
                    android:id="@+id/loginAnimationView"
                    android:layout_width="200dp"
                    android:layout_height="200dp"
                    android:layout_gravity="center"
                    android:layout_marginBottom="8dp"
                    app:lottie_autoPlay="true"
                    app:lottie_loop="true"
                    app:lottie_rawRes="@raw/hello" />

            </LinearLayout>
        </LinearLayout>
    </ScrollView>



    <!-- Contact Info (above the button) -->
    <TextView
        android:id="@+id/contactText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@+id/nextButton"
        android:layout_marginHorizontal="32dp"
        android:layout_marginBottom="12dp"
        android:text="Contact us:\n📧 harshpvt09@gmail.com"
        android:textSize="15sp"
        android:textColor="?android:attr/textColorSecondary"
        android:gravity="center" />

    <!-- Stylish "Get Started" Button -->
    <Button
        android:id="@+id/nextButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_margin="24dp"
        android:text="Get Started"
        android:textColor="#008507"
        android:backgroundTint="#C8FFB4"
        android:textSize="17sp"
        android:textStyle="bold"
        app:strokeColor="#008507"
        app:strokeWidth="2dp"
        android:elevation="8dp"
        android:paddingVertical="14dp"
        android:paddingHorizontal="24dp" />
</RelativeLayout>
