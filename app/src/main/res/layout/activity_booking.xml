<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="20dp">

        <!-- 🔹 App Logo + Title -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:layout_marginTop="22dp"
            android:layout_marginBottom="24dp">

            <ImageView
                android:id="@+id/imgAppLogo"
                android:src="@drawable/logo_cabika"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:contentDescription="App Logo"
            android:layout_marginEnd="12dp" />

            <TextView
                android:id="@+id/tvAppTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cabika"
                android:textSize="40sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:textColor="@android:color/holo_orange_dark"
                android:fontFamily="roboto_black" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvGreeting"
            android:text="Hi! 👋 Ready for your next ride?"
            android:textSize="16sp"
            android:textColor="#333"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"/>

        <LinearLayout
            android:id="@+id/llWhereTo"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:padding="12dp"
            android:background="@drawable/search_box_bg"
            android:gravity="center_vertical"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:src="@drawable/ic_search"
                android:layout_width="24dp"
                android:layout_height="24dp"
                app:tint="#555555"/>

            <TextView
                android:layout_marginStart="12dp"
                android:text="Where to?"
                android:textSize="16sp"
                android:textColor="#888888"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvOngoingTitle"
            android:text="Ongoing Activities"
            android:textSize="14sp"
            android:textColor="#777"
            android:layout_marginTop="24dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerOngoingRides"
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:paddingStart="32dp"
            android:paddingEnd="32dp"
            android:clipToPadding="false"
            android:clipChildren="false"
            android:overScrollMode="never"/>

        <Button
            android:id="@+id/btnViewAllRides"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="View All Rides"
            android:backgroundTint="@color/purple_500"
            android:textColor="@android:color/white" />

    </LinearLayout>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigationView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/nav_background"
        android:fitsSystemWindows="true"
        app:itemIconSize="28dp"
        app:itemIconTint="@color/selector_nav_item_color"
        app:itemTextColor="@color/selector_nav_item_color"
        app:menu="@menu/bottom_nav_menu"
        app:labelVisibilityMode="labeled"
        app:backgroundTint="@null" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
