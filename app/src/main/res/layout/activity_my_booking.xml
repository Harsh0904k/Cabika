<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA">

    <!-- Main content layout -->
    <LinearLayout
        android:id="@+id/contentLayout"
        android:orientation="vertical"
        android:padding="24dp"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:layout_marginBottom="72dp">

        <!-- Title and subtitle -->
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/titleText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="My Bookings"
                android:textSize="28sp"
                android:textStyle="bold"
                android:fontFamily="@font/roboto_black"
                android:textColor="@color/orange_700" />

            <TextView
                android:id="@+id/subtitleText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Click on the ride to edit it"
                android:textSize="14sp"
                android:textColor="#757575"
                android:fontFamily="sans-serif"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Bookings List Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="#FFFFFF">

            <ListView
                android:id="@+id/bookingListView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:divider="#E0E0E0"
                android:dividerHeight="1dp"
                android:padding="12dp" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Start Matching Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/viewMatchedRidesButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Start Matching"
            android:textAllCaps="false"
            android:textColor="#00897B"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            app:cornerRadius="16dp"
            app:strokeColor="#00897B"
            app:strokeWidth="2dp"
            app:backgroundTint="#C0FFE9"
            android:elevation="0dp"
            android:foreground="?attr/selectableItemBackgroundBorderless" />

        <!-- Past Ride -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/viewPastRidesButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Past Rides"
            android:textAllCaps="false"
            android:textColor="#040404"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            app:cornerRadius="16dp"
            app:strokeColor="#000000"
            app:strokeWidth="2dp"
            app:backgroundTint="#FF715F"
            android:elevation="0dp"
            android:foreground="?attr/selectableItemBackgroundBorderless" />

    </LinearLayout>


    <!-- Fullscreen Lottie animation overlay -->
    <FrameLayout
        android:id="@+id/animationOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFFFFF"
        android:visibility="visible">

        <com.airbnb.lottie.LottieAnimationView
            android:id="@+id/lottieProgress"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_gravity="center"
            app:lottie_autoPlay="true"
            app:lottie_loop="true"
            app:lottie_rawRes="@raw/loading" />
    </FrameLayout>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigationView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/nav_background"
        android:fitsSystemWindows="true"
        app:itemIconSize="28dp"
        app:itemIconTint="@color/selector_nav_item_color"
        app:itemTextColor="@color/selector_nav_item_color"
        app:menu="@menu/bottom_nav_menu"
        app:labelVisibilityMode="labeled"
        app:backgroundTint="@null" />

</FrameLayout>
