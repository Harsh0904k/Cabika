<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA">

    <!-- Main vertical layout -->

    <LinearLayout
        android:id="@+id/mainContentLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_marginBottom="72dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- Header always visible -->
        <TextView
            android:id="@+id/myRidesHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ride Details"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            android:fontFamily="@font/roboto_black"
            android:textColor="@color/orange_700"
            android:paddingBottom="12dp" />

        <!-- Lottie animation under header -->
        <com.airbnb.lottie.LottieAnimationView
            android:id="@+id/loadingAnimation"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_gravity="center"
            app:lottie_autoPlay="true"
            app:lottie_loop="true"
            app:lottie_rawRes="@raw/loading" />

        <!-- ScrollView for ride details -->
        <ScrollView
            android:id="@+id/scrollView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            android:paddingTop="16dp">

            <LinearLayout
                android:id="@+id/parentLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Driver Detail Header -->
                <TextView
                    android:id="@+id/txtDriverHeader"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Driver:"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#212121"
                    android:layout_marginBottom="8dp" />

                <!-- Driver Card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/driverCardView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:layout_marginBottom="24dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="8dp"
                    android:background="@color/white"
                    android:clipChildren="false"
                    android:clipToPadding="false">

                    <LinearLayout
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:id="@+id/txtDriverName"
                            android:textStyle="bold"
                            android:textSize="16sp"
                            android:textColor="#000"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                        <TextView
                            android:id="@+id/txtDriverPhone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#555555"
                            android:textSize="14sp"
                            android:layout_marginTop="4dp"/>

                        <TextView
                            android:id="@+id/txtDriverCar"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#555555"
                            android:textSize="14sp"
                            android:layout_marginTop="4dp"/>

                        <!-- Buttons row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_horizontal"
                            android:layout_marginTop="12dp"
                            android:weightSum="2">

                            <Button
                                android:id="@+id/btnCallDriver"
                                android:layout_width="0dp"
                                android:layout_height="40dp"
                                android:layout_weight="1"
                                android:text="Call"
                                android:backgroundTint="@color/teal_700"
                                android:textColor="@android:color/white"
                                android:layout_marginEnd="4dp"/>

                            <Button
                                android:id="@+id/btnWhatsAppDriver"
                                android:layout_width="0dp"
                                android:layout_height="40dp"
                                android:layout_weight="1"
                                android:text="WhatsApp"
                                android:backgroundTint="#25D366"
                                android:textColor="@android:color/white"
                                android:layout_marginStart="4dp"/>
                        </LinearLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>


                <!-- Passenger Detail Header -->
                <TextView
                    android:id="@+id/txtPassengerHeader"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Passengers"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#212121"
                    android:layout_marginBottom="4dp"/>

                <!-- Swipe hint below header -->
                <TextView
                    android:id="@+id/txtSwipeHint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Swipe to see more passengers"
                    android:textSize="12sp"
                    android:textColor="#888888"
                    android:gravity="start"
                    android:layout_marginBottom="8dp"
                    android:fontFamily="sans-serif-medium"/>

                <!-- Passengers RecyclerView -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerPassengers"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:clipToPadding="false"
                    android:paddingStart="32dp"
                    android:paddingEnd="32dp"
                    android:layout_marginBottom="24dp"/>
            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigationView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/nav_background"
        android:fitsSystemWindows="true"
        app:itemIconSize="28dp"
        app:itemIconTint="@color/selector_nav_item_color"
        app:itemTextColor="@color/selector_nav_item_color"
        app:menu="@menu/bottom_nav_menu"
        app:labelVisibilityMode="labeled"
        app:backgroundTint="@null" />
</androidx.coordinatorlayout.widget.CoordinatorLayout>
