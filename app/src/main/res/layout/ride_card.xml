<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/card_background"
    android:layout_margin="8dp">

    <TextView
        android:id="@+id/tvRideRoute"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Pickup → Drop"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@android:color/black"/>

    <TextView
        android:id="@+id/tvRideDateTime"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Date at Time"
        android:textSize="14sp"
        android:textColor="@android:color/darker_gray"
        android:layout_marginTop="4dp"/>

    <TextView
        android:id="@+id/tvPassengers"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Passengers: 0"
        android:textSize="14sp"
        android:textColor="@android:color/holo_blue_dark"
        android:paddingBottom="8dp"/>

    <TextView
        android:id="@+id/tvGirlCabLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Girl Only Cab 🎀"
        android:textColor="@android:color/holo_red_dark"
        android:textStyle="bold"
        android:visibility="gone"
        android:layout_marginTop="4dp"/>

    <Button
        android:id="@+id/btnJoinRide"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Join Ride"
        style="@style/Widget.MaterialComponents.Button"
        android:layout_marginTop="8dp"
        android:backgroundTint="@color/purple_500"
        android:textColor="@android:color/white"/>

</LinearLayout>
