<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@android:color/white"
    android:layout_marginBottom="8dp"
    android:elevation="4dp">

    <!-- Label for joined rides -->
    <TextView
        android:id="@+id/tvRideLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Cabika"
        android:textColor="@color/orange_700"
        android:textStyle="bold"
        android:visibility="gone"
        android:textSize="18sp" />

    <TextView
        android:id="@+id/tvRideName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Driver Ride"
        android:textStyle="bold"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/tvRidePickupDrop"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Pickup → Drop" />

    <TextView
        android:id="@+id/tvRideDateTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Date Time" />

    <TextView
        android:id="@+id/tvRidePassengers"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Passengers: 0" />

    <!-- Delete button for manually added rides -->
    <Button
        android:id="@+id/btnDeleteRide"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Delete"
        android:textAllCaps="false"
        android:backgroundTint="@android:color/holo_red_dark"
        android:textColor="@android:color/white"
        android:layout_marginTop="8dp"
        android:visibility="gone" />
</LinearLayout>
