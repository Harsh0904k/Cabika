<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    card_view:cardCornerRadius="16dp"
    android:layout_margin="4dp"
    card_view:cardElevation="2dp"
    android:layout_marginBottom="12dp"
    android:background="@color/white">

    <LinearLayout
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">

        <!-- Passenger Name -->
        <TextView
            android:id="@+id/txtPassengerName"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="#000"
            android:ellipsize="end"
            android:singleLine="true"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- Registration -->
        <TextView
            android:id="@+id/txtPassengerReg"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:singleLine="true"
            android:textColor="#555555"
            android:textSize="14sp"/>

        <!-- Phone -->
        <TextView
            android:id="@+id/txtPassengerPhone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:singleLine="true"
            android:textColor="#555555"
            android:textSize="14sp"/>

        <!-- Email -->
        <TextView
            android:id="@+id/txtPassengerEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:singleLine="true"
            android:textColor="#555555"
            android:textSize="14sp"/>

        <!-- Passenger Count -->
        <TextView
            android:id="@+id/txtPassengerCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:singleLine="true"
            android:textColor="#555555"
            android:textSize="14sp"/>

        <!-- Buttons Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:weightSum="2">

            <Button
                android:id="@+id/btnCallPassenger"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:text="Call"
                android:backgroundTint="@color/teal_700"
                android:textColor="@android:color/white"
                android:layout_marginEnd="4dp"/>

            <Button
                android:id="@+id/btnWhatsAppPassenger"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:text="Text"
                android:backgroundTint="#25D366"
                android:textColor="@android:color/white"
                android:layout_marginStart="4dp"/>
        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
