<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.hk.vcab">

    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.VIBRATE"/>

    <application
        android:name=".MyApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/mine3"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/mine3_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Vcab"
        tools:targetApi="31">

        <service
            android:name=".MyFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>


        <!-- First screen: -->
        <activity
            android:name=".HomeActivity"
            android:exported="true"
            android:theme="@style/Theme.Vcab">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- Login -->
        <activity
            android:name=".LoginActivity"
            android:exported="true"
            android:theme="@style/Theme.Vcab"/>

        <!-- driver add booking -->
        <activity
            android:name=".DriverAddBookingActivity"
            android:exported="true"
            android:theme="@style/Theme.Vcab"/>

        <!-- driver all booking -->
        <activity
            android:name=".DriverAllRidesActivity"
            android:exported="true"
            android:theme="@style/Theme.Vcab"/>


        <!-- admin -->
        <activity
            android:name=".AdminDashboardActivity"
            android:exported="true"
            android:theme="@style/Theme.Vcab"/>

        <!-- All user -->
        <activity
            android:name=".AllUsersActivity"
            android:exported="true"
            android:theme="@style/Theme.Vcab"/>

        <!-- All driver -->
        <activity
            android:name=".AllDriversActivity"
            android:exported="true"
            android:theme="@style/Theme.Vcab"/>

        <!-- Login -->
        <activity
            android:name=".AllBookingsActivity"
            android:exported="true"
            android:theme="@style/Theme.Vcab"/>

        <!-- coming soon-->
        <activity
            android:name=".ComingSoonActivity"
            android:exported="true"
            android:theme="@style/Theme.Vcab"/>

        <!-- Driver Past Ride-->
        <activity
            android:name=".DriverPastRidesActivity"
            android:exported="true"
            android:theme="@style/Theme.Vcab"/>


        <!-- PastRide-->
        <activity
            android:name=".PastRidesActivity"
            android:exported="true"
            android:theme="@style/Theme.Vcab"/>



        <!-- Driver Available rideE -->
        <activity
            android:name=".DriverBookingActivity"
            android:exported="true"
            android:theme="@style/Theme.Vcab"/>

        <!-- Driver my ride rideE -->
        <activity
            android:name=".DriverAcceptedRideActivity"
            android:exported="true"
            android:theme="@style/Theme.Vcab"/>


        <!-- Driver Accept ride -->
        <activity
            android:name=".DriverAcceptRideActivity"
            android:exported="true"
            android:theme="@style/Theme.Vcab"/>

        <!-- All ride Student -->
        <activity
            android:name=".AllRidesActivity"
            android:exported="true"
            android:theme="@style/Theme.Vcab"/>

        <!-- Join Ride student-->
        <activity
            android:name=".JoinRideActivity"
            android:exported="true"
            android:theme="@style/Theme.Vcab"/>

        <!-- Edit Account -->
        <activity
            android:name=".EditAccountActivity"
            android:exported="true"
            android:theme="@style/Theme.Vcab"/>

        <!-- BookRideActivity -->
        <activity android:name=".BookRideActivity"
            android:exported="true"
            android:theme="@style/Theme.Vcab"/>


        <!-- Account Activity -->
        <activity
            android:name=".AccountActivity"
            android:exported="false"
            android:theme="@style/Theme.Vcab" />


        <!-- Register Activity -->
        <activity
            android:name=".RegisterActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Vcab" />

        <!-- Booking Activity -->
        <activity
            android:name=".BookingActivity"
            android:exported="false"
            android:theme="@style/Theme.Vcab" />


        <activity android:name=".MyBookingActivity"
            android:exported="false"
            android:theme="@style/Theme.Vcab"/>

        <activity android:name=".EditBookingActivity"
            android:exported="false"
            android:theme="@style/Theme.Vcab"/>

        <activity android:name=".MatchedRidesActivity"
            android:parentActivityName=".BookingActivity" >
            <!-- Support older Android versions -->
            <meta-data
                android:name="android.support.PARENT_ACTIVITY"
                android:value=".BookingActivity" />
        </activity>

        <activity android:name=".RideDetailsActivity"
            android:exported="false"
            android:theme="@style/Theme.Vcab"/>


        <activity android:name=".MyRidesActivity"
            android:exported="false"
            android:theme="@style/Theme.Vcab"/>

        <activity android:name=".DashboardActivity"
            android:exported="false"
            android:theme="@style/Theme.Vcab"/>

        <activity android:name=".DriverDashboardActivity"
            android:exported="false"
            android:theme="@style/Theme.Vcab"

            />


    </application>

</manifest>
